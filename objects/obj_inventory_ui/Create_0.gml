/// @description Initialize inventory UI overlay

display_set_gui_size(1280, 720);

inventory_columns = 9;
inventory_rows = 5;

ui_padding_x = 64;
ui_padding_y = 64;
ui_panel_left = 320;
ui_border_size = 8;
ui_inventory_padding = 48;
ui_inventory_box = 64;
ui_inventory_margin = 16;

// Earthy tones to match The Medicine Quest's herbal/nature theme
color_background = #3d4a2f;
color_border = #2a3520;
color_inventory_text = c_white;
color_inventory_highlight = c_lime;
